      <guid isPermaLink="true">https://mastodon.social/@MastodonEngineering/116204764577950180</guid>
      <link>https://mastodon.social/@MastodonEngineering/116204764577950180</link>
      <pubDate>Tue, 10 Mar 2026 11:59:50 +0000</pubDate>
      <description>&lt;p&gt;The February 2026 Trunk &amp;amp; Tidbits is posted. Our monthly engineering update, including progress on 4.6, our AI contribution policy, upcoming end-of-life for version 4.3, some posts about the Share button, and more. &lt;/p&gt;&lt;p&gt;&lt;a href="https://mastodon.social/tags/MastoDev" class="mention hashtag" rel="tag"&gt;#&lt;span&gt;MastoDev&lt;/span&gt;&lt;/a&gt; &lt;a href="https://mastodon.social/tags/MastoAdmin" class="mention hashtag" rel="tag"&gt;#&lt;span&gt;MastoAdmin&lt;/span&gt;&lt;/a&gt; &lt;a href="https://mastodon.social/tags/Mastodon" class="mention hashtag" rel="tag"&gt;#&lt;span&gt;Mastodon&lt;/span&gt;&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;a href="https://blog.joinmastodon.org/2026/03/trunk-tidbits-february-2026/" target="_blank" rel="nofollow noopener" translate="no"&gt;&lt;span class="invisible"&gt;https://&lt;/span&gt;&lt;span class="ellipsis"&gt;blog.joinmastodon.org/2026/03/&lt;/span&gt;&lt;span class="invisible"&gt;trunk-tidbits-february-2026/&lt;/span&gt;&lt;/a&gt;&lt;/p&gt;</description>
