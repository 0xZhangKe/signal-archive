					<comments>https://riichiie.net/2024/12/18/update-on-2024-h2/#respond</comments>
		
		<dc:creator><![CDATA[Richie]]></dc:creator>
		<pubDate>Wed, 18 Dec 2024 15:41:16 +0000</pubDate>
				<category><![CDATA[小兴趣//Hobbies]]></category>
		<category><![CDATA[年月日//Journal]]></category>
		<category><![CDATA[CS2]]></category>
