/td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/%E6%81%8B%E6%84%9B/1728000159\" target=\"_blank\" rel=\"noopener noreferrer\">Love Affair</a></td>\n        <td>2024-02-14</td>\n      </tr>\n      <tr>\n        <td>The Painted Word</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/lovelife/1730037254\" target=\"_blank\" rel=\"noopener noreferrer\">Lovelife</a> (reissue)</td>\n        <td>2024-02-14 (prev. 1989)</td>\n      </tr>\n      <tr>\n        <td>macaroom</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/burning-chrome/1752999536\" target=\"_blank\" rel=\"noopener noreferrer\">Burning Chrome</a></td>\n        <td>2024-07-10</td>\n      </tr>\n      <tr>\n        <td>Hazel English</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/real-life/1757810351\" target=\"_blank\" rel=\"noopener noreferrer\">Real Life</a> (compilation)</td>\n        <td>2024-08-16</td>\n      </tr>\n      <tr>\n        <td>leift</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/citrus/1735442359\" target=\"_blank\" rel=\"noopener noreferrer\">Citrus</a></td>\n        <td>2024-04-03</td>\n      </tr>\n      <tr>\n        <td>Fabiana Palladino</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/fabiana-palladino/1722064179\" target=\"_blank\" rel=\"noopener noreferrer\">Fabiana Palladino</a></td>\n        <td>2024-04-05</td>\n      </tr>\n      <tr>\n        <td>bog band</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/vanity-project-ep/1733626092\" target=\"_blank\" rel=\"noopener noreferrer\">Vanity Project</a> (EP)</td>\n        <td>2024-06-12</td>\n      </tr>\n      <tr>\n        <td>showmore</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/liquid-city/1763795260\" target=\"_blank\" rel=\"noopener noreferrer\">Liquid City</a></td>\n        <td>2024-09-11</td>\n      </tr>\n      <tr>\n        <td>Sabrina Carpenter</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/short-n-sweet/1750307020\" target=\"_blank\" rel=\"noopener noreferrer\">Short ‘n Sweet</a></td>\n        <td>2024-08-23</td>\n      </tr>\n      <tr>\n        <td>Betty Boo</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/rip-up-the-rulebook/1751768472\" target=\"_blank\" rel=\"noopener noreferrer\">Rip Up The Rulebook</a></td>\n        <td>2024-08-30</td>\n      </tr>\n    </tbody>\n  </table>\n\n</div>\n\n<ul>\n  <li><a href=\"https://music.apple.com/gb/playlist/albums-2024/pl.u-NPjBpI04jA1\" target=\"_blank\" rel=\"noopener noreferrer\">Apple Music</a></li>\n  <li><a href=\"https://open.spotify.com/playlist/1xCNxwzvSnV6EUIdcYtc3N?si=6LBNJrmVRE6nTPfJJdoHsQ&amp;pi=e-VbDFOL0PR2GH\" target=\"_blank\" rel=\"noopener noreferrer\">Spotify</a> (missing my number one album)</li>\n</ul>",
