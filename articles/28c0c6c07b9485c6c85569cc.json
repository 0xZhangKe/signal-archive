orgie/1783029153\" target=\"_blank\" rel=\"noopener noreferrer\">Georgie</a></td>\n      </tr>\n      <tr>\n        <td>Album</td>\n        <td>Antony Szmierek</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/service-station-at-the-end-of-the-universe/1767590949\" target=\"_blank\" rel=\"noopener noreferrer\">Service Station At The End Of The Universe</a></td>\n      </tr>\n      <tr>\n        <td>Album</td>\n        <td>MPC GIRL USAGI</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/balance/1844547763\" target=\"_blank\" rel=\"noopener noreferrer\">Balance</a></td>\n      </tr>\n      <tr>\n        <td>Album</td>\n        <td>Your Smith</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/the-rub/1815952643\" target=\"_blank\" rel=\"noopener noreferrer\">The Rub</a></td>\n      </tr>\n      <tr>\n        <td>Album</td>\n        <td>Yuki Kawamura</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/love-forever/1825060989\" target=\"_blank\" rel=\"noopener noreferrer\">Love Forever</a></td>\n      </tr>\n      <tr>\n        <td>Album</td>\n        <td>Osamu Fukuzawa &amp; Kazuki Isogai</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/inner-orchid/1828301887\" target=\"_blank\" rel=\"noopener noreferrer\">Inner Orchid</a></td>\n      </tr>\n      <tr>\n        <td>Album</td>\n        <td>Small Circle of Friends</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/slow/1825352962\" target=\"_blank\" rel=\"noopener noreferrer\">Slow</a></td>\n      </tr>\n      <tr>\n        <td>Album</td>\n        <td>Doja Cat</td>\n        <td><a href=\"https://song.link/https://music.apple.com/gb/album/vie/1834042903\" target=\"_blank\" rel=\"noopener noreferrer\">Vie</a></td>\n      </tr>\n    </tbody>\n  </table>\n\n</div>",
